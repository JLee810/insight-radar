{
  "manifest_version": 3,
  "name": "InsightRadar",
  "version": "1.0.0",
  "description": "AI-powered article tracker. Save and analyze web articles against your interests.",
  "permissions": ["storage", "alarms", "activeTab", "tabs"],
  "host_permissions": ["http://localhost:3001/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "InsightRadar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
